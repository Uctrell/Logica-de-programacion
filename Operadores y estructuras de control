#condicionales
my_variable = "Soy leoncito"
print (my_variable)
if my_variable == "Soy leoncito": #es una condición a cumplir para imprimir algo en este caso 
  print ("hola Leo!")
elif my_variable == "Soy leoncito!": #aquí se abre otra condicional si no se cumple la primera
  print ("Que buena actitud!") 
else: 
  print ("no eres Leo :(")

#iterativas
for i in range (6): #es para recorrer algo sabido en una secuencia, por ejemplo un rango numérico
  print (i)

z=1
while z<6: #aquí usamos while como bucle el cual se ajusta a instrucciones dadas
  print (z) #si el número es menor a 6 se va a seguir imprimiendo
  z += 1 #aquí se le aumenta uno cada vez que el bucle se repite
'''
> python siempre va recorriendo de arriba a abajo, quedandonos esta interpretación:
Ok, z es uno 
si z es menor a seis...
  imprimo z 
  y le aumento uno
> esos espacios son las instrucciones dentro de la función, por eso se sabe que repetir
'''

